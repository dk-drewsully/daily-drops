/* Reward Celebration Overlay - Complete rewrite */
/* Scoped to mobile phone frame container (390×830px) */

/* Overlay container - absolute within phone frame */
.reward-celebration-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  overflow: hidden;
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* Background - semi-transparent with blur */
.reward-background {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(65, 26, 163, 0.95) 0%, rgba(30, 5, 82, 0.95) 100%);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  z-index: 0;
}

/* Blurred orb container */
.reward-orbs-container {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 343px;
  height: 517px;
  overflow: visible;
  z-index: 0;
  pointer-events: none;
}

/* Individual blurred orbs - cyan */
.reward-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(150px);
  opacity: 0.7;
}

.reward-orb-cyan-1 {
  width: 252px;
  height: 292px;
  left: calc(50% + 3px - 138px);
  top: calc(50% + 179px - 52px - 258.5px);
  background: radial-gradient(circle, rgba(0, 224, 255, 1) 0%, rgba(0, 224, 255, 0.8) 50%, rgba(0, 224, 255, 0) 100%);
}

.reward-orb-cyan-2 {
  width: 178px;
  height: 181px;
  left: calc(50% + 189px - 138px);
  top: calc(50% + 78px - 52px - 258.5px);
  background: radial-gradient(circle, rgba(0, 224, 255, 1) 0%, rgba(0, 224, 255, 0.8) 50%, rgba(0, 224, 255, 0) 100%);
}

.reward-orb-cyan-3 {
  width: 136px;
  height: 136px;
  left: calc(50% + 0px - 138px);
  top: calc(50% + 145px - 52px - 258.5px);
  background: radial-gradient(circle, rgba(0, 224, 255, 1) 0%, rgba(0, 224, 255, 0.8) 50%, rgba(0, 224, 255, 0) 100%);
}

.reward-orb-cyan-4 {
  width: 204px;
  height: 204px;
  left: calc(50% + 162px - 138px);
  top: calc(50% + 98px - 52px - 258.5px);
  background: radial-gradient(circle, rgba(0, 224, 255, 1) 0%, rgba(0, 224, 255, 0.8) 50%, rgba(0, 224, 255, 0) 100%);
}

/* Yellow orb */
.reward-orb-yellow {
  width: 135px;
  height: 183px;
  left: calc(50% + 134px - 138px);
  top: calc(50% + 39px - 52px - 258.5px);
  background: radial-gradient(circle, rgba(250, 255, 0, 1) 0%, rgba(250, 255, 0, 0.8) 50%, rgba(250, 255, 0, 0) 100%);
}

/* Starburst background element with blur */
.reward-starburst {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) scale(1.8);
  width: 375px;
  height: 480px;
  background-image: url('../assets/images/reward-star-burst.svg');
  background-size: contain;
  background-repeat: no-repeat;
  background-position: center;
  /* No extra blur - SVG has it built-in */
  opacity: 1;
  z-index: 1;
  animation: starburst-pulse 3s ease-in-out infinite alternate;
  mix-blend-mode: screen;
}

@keyframes starburst-pulse {
  from {
    opacity: 0.8;
    transform: translate(-50%, -50%) scale(1.8);
  }
  to {
    opacity: 1;
    transform: translate(-50%, -50%) scale(1.9);
  }
}

/* Coins container with perspective for flip effect */
.reward-coins-container {
  position: absolute;
  inset: 0;
  perspective: 200px;
  pointer-events: none;
  z-index: 1;
}

/* Individual coin - small flat circle */
.reward-coin {
  position: absolute;
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: radial-gradient(circle at 35% 35%, #FFD700 0%, #FFA000 100%);
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.3);

  /* Start at container center */
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);

  /* Fire outward to final position */
  animation:
    coin-burst var(--duration) ease-out var(--delay) forwards,
    coin-bob 1.5s ease-in-out calc(var(--duration) + var(--delay)) infinite alternate,
    coin-flip 2s linear calc(var(--duration) + var(--delay)) infinite;
}

@keyframes coin-burst {
  from {
    left: 50%;
    top: 50%;
  }
  to {
    left: var(--final-x);
    top: var(--final-y);
  }
}

@keyframes coin-bob {
  from {
    transform: translate(-50%, calc(-50% - 8px));
  }
  to {
    transform: translate(-50%, calc(-50% + 8px));
  }
}

@keyframes coin-flip {
  from {
    transform: translate(-50%, -50%) rotateY(0deg);
  }
  to {
    transform: translate(-50%, -50%) rotateY(360deg);
  }
}

/* Confetti container */
.reward-confetti-container {
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 3;
}

/* Individual confetti piece - small rectangle */
.reward-confetti-piece {
  position: absolute;
  width: 12px;
  height: 20px;
  border-radius: 2px;
  box-shadow: 0 3px 8px rgba(0, 0, 0, 0.5), 0 1px 3px rgba(0, 0, 0, 0.3);
  opacity: 1;

  /* Start at container center */
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%) rotate(var(--rotation));

  /* Burst outward then fall */
  animation:
    confetti-burst 200ms ease-out var(--delay) forwards,
    confetti-fall var(--fall-duration) ease-in calc(200ms + var(--delay)) forwards,
    confetti-rotate calc(var(--fall-duration) + 200ms) linear var(--delay) infinite;
}

@keyframes confetti-burst {
  from {
    transform: translate(-50%, -50%) rotate(var(--rotation));
  }
  to {
    transform: translate(calc(-50% + var(--outward-x)), calc(-50% + var(--outward-y))) rotate(var(--rotation));
  }
}

@keyframes confetti-fall {
  from {
    top: 50%;
    opacity: 1;
  }
  80% {
    opacity: 1;
  }
  to {
    top: 130%;
    opacity: 0;
  }
}

@keyframes confetti-rotate {
  from {
    transform: translate(calc(-50% + var(--outward-x)), calc(-50% + var(--outward-y))) rotate(var(--rotation));
  }
  to {
    transform: translate(calc(-50% + var(--outward-x)), calc(-50% + var(--outward-y))) rotate(calc(var(--rotation) + var(--rotation-speed)));
  }
}

/* Copy container - centered above particles */
.reward-copy-container {
  position: relative;
  z-index: 10;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-align: center;
}

/* Crown container with circles */
.reward-crown-container {
  position: relative;
  width: 193px;
  height: 193px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 24px 0;
}

/* Concentric circles around crown */
.reward-circle-outer {
  position: absolute;
  width: 193px;
  height: 193px;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
  z-index: 8;
  top: 0;
  left: 0;
  pointer-events: none;
}

.reward-circle-inner {
  position: absolute;
  width: 148px;
  height: 147px;
  border-radius: 50%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.04) 100%);
  z-index: 9;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

/* Crown icon container */
.reward-crown-icon {
  width: 100px;
  height: 100px;
  z-index: 10;
  position: relative;
}

/* "YOU WON" - fades in at t=500ms */
.reward-copy-title {
  font-family: 'Grota Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 1.2rem;
  font-weight: 600;
  color: #ffffff;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  opacity: 0;
  animation: text-fade-in 300ms ease-out 500ms forwards;
}

@keyframes text-fade-in {
  from {
    opacity: 0;
  }
  to {
    opacity: 1;
  }
}

/* Amount - spring bounce at t=700ms */
.reward-copy-amount {
  font-family: 'Grota Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 5rem;
  font-weight: 900;
  color: #FFB800;
  text-shadow: 0 4px 16px rgba(255, 184, 0, 0.6);
  line-height: 1;
  opacity: 0;
  animation: amount-spring 400ms cubic-bezier(0.34, 1.56, 0.64, 1) 700ms forwards;
}

@keyframes amount-spring {
  from {
    opacity: 0;
    transform: scale(0.5);
  }
  60% {
    transform: scale(1.05);
  }
  to {
    opacity: 1;
    transform: scale(1.8);
  }
}

/* Label - fades in at t=900ms */
.reward-copy-label {
  font-family: 'Grota Sans', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 1.4rem;
  font-weight: 700;
  color: #ffffff;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
  opacity: 0;
  animation: text-fade-in 300ms ease-out 900ms forwards;
}

.reward-celebration-overlay.exiting .reward-copy-container {
  animation: exit-copy 150ms ease-out forwards;
}

.reward-celebration-overlay.exiting .reward-coin,
.reward-celebration-overlay.exiting .reward-confetti-piece {
  animation: exit-particles 200ms ease-out 150ms forwards;
}

.reward-celebration-overlay.exiting {
  animation: exit-overlay 250ms ease-out 350ms forwards;
}

@keyframes exit-copy {
  to {
    opacity: 0;
  }
}

@keyframes exit-particles {
  to {
    opacity: 0;
  }
}

@keyframes exit-overlay {
  to {
    opacity: 0;
  }
}

/* Reduced motion support */
@media (prefers-reduced-motion: reduce) {
  .reward-coin,
  .reward-confetti-piece {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
  }

  .reward-copy-title,
  .reward-copy-amount,
  .reward-copy-label {
    opacity: 1 !important;
    transform: none !important;
    animation: none !important;
  }
}
